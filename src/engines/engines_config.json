{
    "cuda": {
        "description": "NVIDIA CUDA 12.8 (Turing→Blackwell, Qwen3.5 ready)",
        "package_source": "local",
        "local_wheel": "llama_cpp_python-0.3.32+cu128-cp312-cp312-win_amd64.whl",
        "version": "0.3.32",
        "target_dir": "src/engines/cuda",
        "install_args": [
            "--force-reinstall",
            "--no-cache-dir",
            "--verbose"
        ],
        "env_vars": {}
    },
    "vulkan": {
        "description": "Vulkan (Universal/AMD/Intel, Qwen3.5 ready)",
        "package_source": "local",
        "local_wheel": "llama_cpp_python-0.3.32+vulkan-cp312-cp312-win_amd64.whl",
        "version": "0.3.32",
        "target_dir": "src/engines/vulkan",
        "install_args": [
            "--force-reinstall",
            "--no-cache-dir",
            "--verbose"
        ],
        "env_vars": {
            "CMAKE_ARGS": "-DGGML_VULKAN=on",
            "FORCE_CMAKE": "1"
        }
    }
}